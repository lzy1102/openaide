package services

import (
	"context"
	"testing"
	"time"

	"openaide/backend/src/models"

	"github.com/google/uuid"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
	"github.com/glebarez/sqlite"
	"gorm.io/gorm"
)

// setupTestDBForTemplate 创建测试数据库
func setupTestDBForTemplate(t *testing.T) *gorm.DB {
	db, err := gorm.Open(sqlite.Open("file::memory:?cache=shared"), &gorm.Config{})
	require.NoError(t, err)

	err = db.AutoMigrate(
		&models.PromptTemplate{},
		&models.PromptInstance{},
	)
	require.NoError(t, err)

	return db
}

// setupTestPromptTemplateService 创建测试服务
func setupTestPromptTemplateService(t *testing.T) *PromptTemplateService {
	db := setupTestDBForTemplate(t)
	cache := NewCacheService()
	logger, _ := NewLoggerService(LogLevelInfo, "")

	return NewPromptTemplateService(db, cache, logger)
}

// TestNewPromptTemplateService 测试服务初始化
func TestNewPromptTemplateService(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	assert.NotNil(t, service)
	assert.NotNil(t, service.db)
	assert.NotNil(t, service.cache)
	assert.NotNil(t, service.logger)
}

// TestInitDefaultTemplates 测试默认模板初始化
func TestInitDefaultTemplates(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 验证默认模板已创建
	defaultTemplateNames := []string{
		"default_system",
		"thinking_system",
		"code_assistant",
		"task_decompose",
		"summarize",
	}

	for _, name := range defaultTemplateNames {
		template, err := service.GetTemplateByName(name)
		assert.NoError(t, err, "Default template %s should exist", name)
		assert.NotNil(t, template)
		assert.True(t, template.IsActive)
		assert.Equal(t, name, template.Name)
	}

	// 验证版本号
	defaultSystem, _ := service.GetTemplateByName("default_system")
	assert.Equal(t, "1.0.0", defaultSystem.Version)
}

// TestCreateTemplate 测试创建模板
func TestCreateTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:        "test_template",
		Description: "Test template",
		Category:    "user",
		Template:    "Hello {{.name}}, welcome to {{.app}}!",
		Variables: []models.PromptVariable{
			{Name: "name", Type: "string", Description: "User name", Required: true},
			{Name: "app", Type: "string", Description: "Application name", DefaultValue: "MyApp", Required: false},
		},
		Tags:     []string{"greeting", "test"},
		Version:  "1.0.0",
		IsActive: true,
	}

	err := service.CreateTemplate(template)
	assert.NoError(t, err)
	assert.NotEmpty(t, template.ID)

	// 验证模板已保存
	retrieved, err := service.GetTemplate(template.ID)
	assert.NoError(t, err)
	assert.Equal(t, "test_template", retrieved.Name)
}

// TestCreateTemplateWithInvalidSyntax 测试无效模板语法
func TestCreateTemplateWithInvalidSyntax(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:        "invalid_template",
		Description: "Template with invalid syntax",
		Category:    "user",
		Template:    "Hello {{.name", // 缺少闭合括号
		Variables:   []models.PromptVariable{},
	}

	err := service.CreateTemplate(template)
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "invalid template syntax")
}

// TestGetTemplate 测试获取模板
func TestGetTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 创建测试模板
	template := &models.PromptTemplate{
		Name:        "test_get",
		Description: "Test get template",
		Category:    "test",
		Template:    "Test content {{.var}}",
		Variables: []models.PromptVariable{
			{Name: "var", Type: "string", Description: "Variable"},
		},
		IsActive: true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	// 通过ID获取
	retrieved, err := service.GetTemplate(template.ID)
	assert.NoError(t, err)
	assert.Equal(t, "test_get", retrieved.Name)

	// 测试缓存 - 再次获取应该从缓存读取
	retrieved2, err := service.GetTemplate(template.ID)
	assert.NoError(t, err)
	assert.Equal(t, retrieved.ID, retrieved2.ID)

	// 测试不存在的模板
	_, err = service.GetTemplate("non-existent-id")
	assert.Error(t, err)
}

// TestGetTemplateByName 测试通过名称获取模板
func TestGetTemplateByName(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template, err := service.GetTemplateByName("default_system")
	assert.NoError(t, err)
	assert.NotNil(t, template)
	assert.Equal(t, "default_system", template.Name)

	// 测试不存在的模板
	_, err = service.GetTemplateByName("non-existent-template")
	assert.Error(t, err)
}

// TestListTemplates 测试列出模板
func TestListTemplates(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 创建测试模板
	templates := []models.PromptTemplate{
		{Name: "test1", Category: "test", Template: "Content 1", IsActive: true, Tags: []string{"tag1"}},
		{Name: "test2", Category: "test", Template: "Content 2", IsActive: true, Tags: []string{"tag2"}},
		{Name: "test3", Category: "production", Template: "Content 3", IsActive: true, Tags: []string{"tag1"}},
		{Name: "test4", Category: "test", Template: "Content 4", IsActive: false}, // 非活跃
	}

	for _, tmpl := range templates {
		tmpl.ID = uuid.New().String()
		tmpl.CreatedAt = time.Now()
		tmpl.UpdatedAt = time.Now()
		service.db.Create(&tmpl)
	}

	// 测试列出所有活跃模板
	all, err := service.ListTemplates("", nil)
	assert.NoError(t, err)
	// 包含默认模板 + 测试模板
	assert.GreaterOrEqual(t, len(all), 3)

	// 测试按类别过滤
	testTemplates, err := service.ListTemplates("test", nil)
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(testTemplates), 2)

	// 测试按标签过滤
	taggedTemplates, err := service.ListTemplates("", []string{"tag1"})
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(taggedTemplates), 1)
}

// TestUpdateTemplate 测试更新模板
func TestUpdateTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:        "test_update",
		Description: "Original description",
		Category:    "test",
		Template:    "Original template {{.var}}",
		Variables:   []models.PromptVariable{{Name: "var", Type: "string"}},
		IsActive:    true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	// 更新模板
	updates := map[string]interface{}{
		"description": "Updated description",
		"template":    "Updated template {{.var}}",
	}

	err = service.UpdateTemplate(template.ID, updates)
	assert.NoError(t, err)

	// 验证更新
	retrieved, _ := service.GetTemplate(template.ID)
	assert.Equal(t, "Updated description", retrieved.Description)
	assert.Equal(t, "Updated template {{.var}}", retrieved.Template)

	// 验证缓存已清除
	// 重新创建服务实例以绕过内存缓存
	cacheKey := "prompt_template:" + template.ID
	_, found := service.cache.Get(cacheKey)
	assert.False(t, found, "Cache should be cleared after update")
}

// TestDeleteTemplate 测试删除模板（软删除）
func TestDeleteTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:        "test_delete",
		Description: "Template to delete",
		Category:    "test",
		Template:    "Delete me {{.var}}",
		Variables:   []models.PromptVariable{{Name: "var", Type: "string"}},
		IsActive:    true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	// 删除模板
	err = service.DeleteTemplate(template.ID)
	assert.NoError(t, err)

	// 验证软删除 - 模板仍然存在但不再活跃
	var dbTemplate models.PromptTemplate
	err = service.db.First(&dbTemplate, "id = ?", template.ID).Error
	assert.NoError(t, err)
	assert.False(t, dbTemplate.IsActive)

	// 验证无法通过正常方法获取
	_, err = service.GetTemplate(template.ID)
	assert.Error(t, err)
}

// TestRenderTemplate 测试渲染模板
func TestRenderTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 创建测试模板
	template := &models.PromptTemplate{
		Name:        "test_render",
		Description: "Test render",
		Category:    "test",
		Template: `Hello {{.name}}!
Current date: {{.current_date}}
{{if .custom_message}}Custom: {{.custom_message}}{{end}}
`,
		Variables: []models.PromptVariable{
			{Name: "name", Type: "string", Required: true},
			{Name: "custom_message", Type: "string", Required: false},
		},
		IsActive: true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	// 渲染模板
	variables := map[string]interface{}{
		"name":           "Alice",
		"custom_message": "Welcome back!",
	}

	result, err := service.RenderTemplate(template.ID, variables)
	assert.NoError(t, err)
	assert.Contains(t, result, "Hello Alice!")
	assert.Contains(t, result, "Custom: Welcome back!")
	assert.Contains(t, result, "Current date:")

	// 测试使用默认值
	variables2 := map[string]interface{}{
		"name": "Bob",
	}
	result2, err := service.RenderTemplate(template.ID, variables2)
	assert.NoError(t, err)
	assert.Contains(t, result2, "Hello Bob!")
	assert.NotContains(t, result2, "Custom:")
}

// TestRenderTemplateWithBuiltInVariables 测试内置变量
func TestRenderTemplateWithBuiltInVariables(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:     "builtin_vars",
		Category: "test",
		Template: "Date: {{.current_date}}, Time: {{.current_time}}, DateTime: {{.current_datetime}}",
		Variables: []models.PromptVariable{
			{Name: "current_date", Type: "string", DefaultValue: "", Required: false},
			{Name: "current_time", Type: "string", DefaultValue: "", Required: false},
			{Name: "current_datetime", Type: "string", DefaultValue: "", Required: false},
		},
		IsActive: true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	result, err := service.RenderTemplate(template.ID, map[string]interface{}{})
	assert.NoError(t, err)

	// 验证内置变量已填充
	now := time.Now()
	expectedDate := now.Format("2006-01-02")
	expectedTime := now.Format("15:04:05")
	expectedDateTime := now.Format("2006-01-02 15:04:05")

	assert.Contains(t, result, expectedDate)
	assert.Contains(t, result, expectedTime)
	assert.Contains(t, result, expectedDateTime)
}

