// TestRenderWithConditional 测试条件渲染
func TestRenderWithConditional(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:     "conditional_test",
		Category: "test",
		Template: `{{if .show_greeting}}Hello!{{else}}Goodbye!{{end}}`,
		Variables: []models.PromptVariable{
			{Name: "show_greeting", Type: "boolean", DefaultValue: "false", Required: false},
		},
		IsActive: true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	// 测试条件为真
	result1, _ := service.RenderTemplate(template.ID, map[string]interface{}{"show_greeting": true})
	assert.Contains(t, result1, "Hello!")

	// 测试条件为假
	result2, _ := service.RenderTemplate(template.ID, map[string]interface{}{"show_greeting": false})
	assert.Contains(t, result2, "Goodbye!")
}

// TestExtractVariables 测试从模板提取变量
func TestExtractVariables(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	templateStr := `Hello {{.name}}, your role is {{.role}}.
{{if .custom}}Custom message: {{.custom}}{{end}}
Date: {{.current_date}}
`

	variables := service.ExtractVariables(templateStr)

	assert.Contains(t, variables, "name")
	assert.Contains(t, variables, "role")
	assert.Contains(t, variables, "custom")
	assert.Contains(t, variables, "current_date")
	assert.Len(t, variables, 4)
}

// TestCreateVersion 测试创建新版本
func TestCreateVersion(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 创建原始模板
	original := &models.PromptTemplate{
		Name:        "version_test",
		Description: "Original version",
		Category:    "test",
		Template:    "Original {{.content}}",
		Variables: []models.PromptVariable{
			{Name: "content", Type: "string", Required: true},
		},
		Version:  "1.0.0",
		IsActive: true,
		IsDefault: true,
	}
	err := service.CreateTemplate(original)
	require.NoError(t, err)

	// 创建新版本
	newVariables := []models.PromptVariable{
		{Name: "content", Type: "string", Required: true},
		{Name: "style", Type: "string", Required: false},
	}

	newVersion, err := service.CreateVersion(original.ID, "New {{.content}} with {{.style}}", newVariables)
	assert.NoError(t, err)
	assert.NotNil(t, newVersion)

	// 验证新版本
	assert.Equal(t, "version_test", newVersion.Name)
	assert.Equal(t, "1.1.0", newVersion.Version) // minor version incremented
	assert.Equal(t, original.ID, newVersion.ParentID)
	assert.False(t, newVersion.IsDefault)

	// 验证原版本不再是默认
	var orig models.PromptTemplate
	service.db.First(&orig, original.ID)
	assert.False(t, orig.IsDefault)
}

// TestGetVersions 测试获取版本历史
func TestGetVersions(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 创建多个版本
	original := &models.PromptTemplate{
		Name:        "multi_version",
		Description: "Multi version test",
		Category:    "test",
		Template:    "V1 {{.content}}",
		Variables:   []models.PromptVariable{{Name: "content", Type: "string"}},
		Version:     "1.0.0",
		IsActive:    true,
	}
	err := service.CreateTemplate(original)
	require.NoError(t, err)

	// 创建第二个版本
	v2, _ := service.CreateVersion(original.ID, "V2 {{.content}}", []models.PromptVariable{{Name: "content", Type: "string"}})
	require.NoError(t, err)

	// 创建第三个版本
	_, err = service.CreateVersion(v2.ID, "V3 {{.content}}", []models.PromptVariable{{Name: "content", Type: "string"}})
	require.NoError(t, err)

	// 获取所有版本
	versions, err := service.GetVersions("multi_version")
	assert.NoError(t, err)
	assert.Len(t, versions, 3)

	// 验证版本按时间倒序排列
	assert.Equal(t, "1.2.0", versions[0].Version)
	assert.Equal(t, "1.1.0", versions[1].Version)
	assert.Equal(t, "1.0.0", versions[2].Version)
}

// TestMergeWithDefaults 测试默认值合并
func TestMergeWithDefaults(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	variables := []models.PromptVariable{
		{Name: "required_var", Type: "string", Required: true, DefaultValue: ""},
		{Name: "optional_var", Type: "string", Required: false, DefaultValue: "default_value"},
		{Name: "number_var", Type: "number", Required: false, DefaultValue: "42"},
	}

	provided := map[string]interface{}{
		"required_var": "provided_value",
		"custom_var":   "custom_value", // 不在定义中的变量
	}

	result := service.mergeWithDefaults(variables, provided)

	assert.Equal(t, "provided_value", result["required_var"])
	assert.Equal(t, "default_value", result["optional_var"])
	assert.Equal(t, "42", result["number_var"])
	assert.Equal(t, "custom_value", result["custom_var"])

	// 验证内置变量存在
	assert.Contains(t, result, "current_date")
	assert.Contains(t, result, "current_time")
	assert.Contains(t, result, "current_datetime")
}

// TestValidateTemplate 测试模板验证
func TestValidateTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 有效的模板
	validTemplates := []string{
		"Hello {{.name}}",
		"{{if .show}}Show{{end}}",
		"{{range .items}}{{.}}{{end}}",
		"No variables",
	}

	for _, tmpl := range validTemplates {
		err := service.validateTemplate(tmpl)
		assert.NoError(t, err, "Template should be valid: %s", tmpl)
	}

	// 无效的模板
	invalidTemplates := []string{
		"Hello {{.name",  // 未闭合
		"{{if .show}}",   // 未闭合的if
		"{{undefined}}",  // 未定义函数
	}

	for _, tmpl := range invalidTemplates {
		err := service.validateTemplate(tmpl)
		assert.Error(t, err, "Template should be invalid: %s", tmpl)
	}
}

// TestExportTemplates 测试导出模板
func TestExportTemplates(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 创建测试模板
	tmpl1 := &models.PromptTemplate{
		Name:     "export_test_1",
		Category: "test",
		Template: "Template 1",
		IsActive: true,
	}
	tmpl2 := &models.PromptTemplate{
		Name:     "export_test_2",
		Category: "test",
		Template: "Template 2",
		IsActive: true,
	}

	err := service.CreateTemplate(tmpl1)
	require.NoError(t, err)
	err = service.CreateTemplate(tmpl2)
	require.NoError(t, err)

	// 导出
	data, err := service.ExportTemplates([]string{tmpl1.ID, tmpl2.ID})
	assert.NoError(t, err)
	assert.NotEmpty(t, data)

	// 验证JSON格式
	var exported []models.PromptTemplate
	err = exported.UnmarshalJSON(data)
	assert.NoError(t, err)
	assert.Len(t, exported, 2)
}

// TestImportTemplates 测试导入模板
func TestImportTemplates(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	// 准备导入数据
	importData := []models.PromptTemplate{
		{
			Name:     "imported_template_1",
			Category: "test",
			Template: "Imported 1",
		},
		{
			Name:     "imported_template_2",
			Category: "test",
			Template: "Imported 2",
		},
	}

	jsonData, _ := importData.MarshalJSON()

	// 导入（不覆盖）
	count, err := service.ImportTemplates(jsonData, false)
	assert.NoError(t, err)
	assert.Equal(t, 2, count)

	// 验证模板已创建
	_, err = service.GetTemplateByName("imported_template_1")
	assert.NoError(t, err)

	// 再次导入（覆盖模式）
	count, err = service.ImportTemplates(jsonData, true)
	assert.NoError(t, err)
	assert.Equal(t, 2, count)
}

// TestTemplateUseCount 测试使用计数
func TestTemplateUseCount(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	template := &models.PromptTemplate{
		Name:     "count_test",
		Category: "test",
		Template: "{{.var}}",
		Variables: []models.PromptVariable{{Name: "var", Type: "string"}},
		IsActive: true,
	}
	err := service.CreateTemplate(template)
	require.NoError(t, err)

	// 初始计数
	assert.Equal(t, int64(0), template.UseCount)

	// 渲染多次
	for i := 0; i < 3; i++ {
		_, _ = service.RenderTemplate(template.ID, map[string]interface{}{"var": "test"})
	}

	// 等待异步更新完成
	time.Sleep(100 * time.Millisecond)

	// 验证计数增加
	var updated models.PromptTemplate
	service.db.First(&updated, template.ID)
	assert.GreaterOrEqual(t, updated.UseCount, int64(3))
}

// BenchmarkTemplateRendering 性能测试
func BenchmarkTemplateRendering(b *testing.B) {
	service := setupTestPromptTemplateService(&testing.T{})

	template := &models.PromptTemplate{
		Name:     "bench",
		Category: "test",
		Template: "Hello {{.name}}, date: {{.current_date}}",
		Variables: []models.PromptVariable{
			{Name: "name", Type: "string"},
			{Name: "current_date", Type: "string"},
		},
		IsActive: true,
	}
	service.CreateTemplate(template)

	variables := map[string]interface{}{"name": "Benchmark"}

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		service.RenderTemplate(template.ID, variables)
	}
}

// TestComplexTemplate 测试复杂模板
func TestComplexTemplate(t *testing.T) {
	service := setupTestPromptTemplateService(t)

	complexTemplate := &models.PromptTemplate{
		Name: "complex",
		Category: "test",
		Template: `System Instructions:
{{- range .instructions}}
- {{.}}
{{- end}}

User Profile:
{{if .user}}
Name: {{.user.name}}
Email: {{.user.email}}
{{else}}
No user information
{{end}}

{{if .tasks}}
Tasks:
{{range .tasks}}
- {{.name}} - {{.status}}
{{end}}
{{end}}`,
		Variables: []models.PromptVariable{
			{Name: "instructions", Type: "array", Required: false},
			{Name: "user", Type: "object", Required: false},
			{Name: "tasks", Type: "array", Required: false},
		},
		IsActive: true,
	}
	err := service.CreateTemplate(complexTemplate)
	require.NoError(t, err)

	variables := map[string]interface{}{
		"instructions": []string{"Be helpful", "Be concise", "Be accurate"},
		"user": map[string]interface{}{
			"name":  "Alice",
			"email": "alice@example.com",
		},
		"tasks": []map[string]interface{}{
			{"name": "Task 1", "status": "done"},
			{"name": "Task 2", "status": "in progress"},
		},
	}

	result, err := service.RenderTemplate(complexTemplate.ID, variables)
	assert.NoError(t, err)
	assert.Contains(t, result, "Be helpful")
	assert.Contains(t, result, "Alice")
	assert.Contains(t, result, "alice@example.com")
	assert.Contains(t, result, "Task 1")
}
