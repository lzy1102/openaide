func TestAggregateResultsNonExistentTeam(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	_, err := orchestrator.AggregateResults("non-existent-team")
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "not found")
}

// TestHandleFailure 测试处理失败
func TestHandleFailure(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	// 创建团队和任务
	plan := &TeamPlan{
		ID:          uuid.New().String(),
		Name:        "Failure Test Team",
		Description: "Test failure handling",
		Members: []TeamMemberPlan{
			{
				ID:   uuid.New().String(),
				Name: "Failure Handler",
				Role: "handler",
				Capabilities: []string{"handling"},
			},
		},
		Tasks: []TaskPlanItem{
			{
				ID:          uuid.New().String(),
				Title:       "Failing Task",
				Description: "A task that will fail",
				Type:        "testing",
				Priority:    "high",
				AssignedTo:  "",
				Estimated:   10,
			},
		},
		CreatedAt: time.Now(),
	}
	plan.Tasks[0].AssignedTo = plan.Members[0].ID

	team, err := orchestrator.CreateTeamFromPlan(plan)
	require.NoError(t, err)

	// 获取任务ID
	var task models.Task
	orchestrator.db.Where("team_id = ? AND title = ?", team.ID, "Failing Task").First(&task)
	require.NotEmpty(t, task.ID)

	// 第一次失败 - 应该重试
	err = orchestrator.HandleFailure(team.ID, task.ID)
	assert.NoError(t, err)

	orchestrator.db.First(&task, task.ID)
	assert.Equal(t, "pending", task.Status)
	assert.Equal(t, 1, task.RetryCount)

	// 超过最大重试次数
	task.RetryCount = 3
	task.MaxRetries = 3
	orchestrator.db.Save(&task)

	err = orchestrator.HandleFailure(team.ID, task.ID)
	assert.NoError(t, err)

	orchestrator.db.First(&task, task.ID)
	assert.Equal(t, "failed", task.Status)
}

// TestBuildTaskPrompt 测试构建任务提示
func TestBuildTaskPrompt(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	task := &models.Task{
		Title:       "Test Task",
		Description: "A test task description",
		Type:        "coding",
		Priority:    "high",
		Context: models.TaskContext{
			Metadata: map[string]interface{}{
				"key": "value",
			},
		},
	}

	agent := &AgentInstance{
		Name: "TestAgent",
		Role: "developer",
	}

	prompt := orchestrator.buildTaskPrompt(task, agent)

	assert.Contains(t, prompt, "TestAgent")
	assert.Contains(t, prompt, "developer")
	assert.Contains(t, prompt, "Test Task")
	assert.Contains(t, prompt, "A test task description")
	assert.Contains(t, prompt, "coding")
	assert.Contains(t, prompt, "high")
}

// TestAreDependenciesComplete 测试依赖完成检查
func TestAreDependenciesComplete(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	execution := &TeamExecution{
		TeamID:        "test-team",
		CompletedTasks: make(map[string]bool),
	}

	task := &models.Task{
		ID: "task-1",
		Dependencies: []models.TaskDependency{
			{DependsOn: "dep-1"},
			{DependsOn: "dep-2"},
		},
	}

	// 依赖未完成
	assert.False(t, orchestrator.areDependenciesComplete(execution, task))

	// 部分依赖完成
	execution.CompletedTasks["dep-1"] = true
	assert.False(t, orchestrator.areDependenciesComplete(execution, task))

	// 所有依赖完成
	execution.CompletedTasks["dep-2"] = true
	assert.True(t, orchestrator.areDependenciesComplete(execution, task))
}

// TestGenerateFinalOutput 测试生成最终输出
func TestGenerateFinalOutput(t *testing.T) {
	summary := TaskResultSummary{
		Total:     10,
		Completed: 8,
		Failed:    2,
	}

	results := []MemberResult{
		{
			MemberName:      "Alice",
			Role:            "developer",
			TasksCompleted:  5,
			TasksAssigned:   6,
			TasksFailed:     1,
		},
		{
			MemberName:      "Bob",
			Role:            "tester",
			TasksCompleted:  3,
			TasksAssigned:   4,
			TasksFailed:     1,
		},
	}

	output := generateFinalOutput(summary, results)

	assert.Contains(t, output, "Team Execution Summary")
	assert.Contains(t, output, "Total Tasks: 10")
	assert.Contains(t, output, "Completed: 8")
	assert.Contains(t, output, "Failed: 2")
	assert.Contains(t, output, "80.0%")
	assert.Contains(t, output, "Alice")
	assert.Contains(t, output, "Bob")
}

// BenchmarkCreateTeamFromPlan 性能测试
func BenchmarkCreateTeamFromPlan(b *testing.B) {
	db, _ := gorm.Open(sqlite.Open("file::memory:?cache=shared"), &gorm.Config)
	db.AutoMigrate(&models.Team{}, &models.TeamMember{}, &models.Task{}, &models.TaskDependency{})

	logger := NewLoggerService()
	coordinator := services.NewSimpleTeamCoordinatorService(db, nil)
	llmFactory := llm.NewLLMClientFactory()
	orchestrator := NewTeamOrchestrator(db, coordinator, llmFactory, logger)

	plan := &TeamPlan{
		ID:    uuid.New().String(),
		Name:  "Benchmark Team",
		Members: []TeamMemberPlan{
			{ID: uuid.New().String(), Name: "M1", Role: "dev"},
			{ID: uuid.New().String(), Name: "M2", Role: "tester"},
		},
		Tasks: []TaskPlanItem{
			{ID: uuid.New().String(), Title: "T1", AssignedTo: ""},
			{ID: uuid.New().String(), Title: "T2", AssignedTo: ""},
		},
	}
	plan.Tasks[0].AssignedTo = plan.Members[0].ID
	plan.Tasks[1].AssignedTo = plan.Members[1].ID

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		orchestrator.CreateTeamFromPlan(plan)
	}
}
