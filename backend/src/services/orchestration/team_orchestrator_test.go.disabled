// setupTestDB 创建测试数据库
func setupTestDB(t *testing.T) *gorm.DB {
	db, err := gorm.Open(sqlite.Open("file::memory:?cache=shared"), &gorm.Config{})
	require.NoError(t, err)

	// 自动迁移所有模型
	err = db.AutoMigrate(
		&models.Team{},
		&models.TeamMember{},
		&models.TeamMessage{},
		&models.TeamActivity{},
		&models.TeamMetrics{},
		&models.Task{},
		&models.Subtask{},
		&models.TaskDependency{},
		&models.SubtaskDependency{},
		&models.ProgressReport{},
		&models.TaskResult{},
	)
	require.NoError(t, err)

	return db
}

// setupTestOrchestrator 创建测试编排器
func setupTestOrchestrator(t *testing.T) *TeamOrchestrator {
	db := setupTestDB(t)
	logger := NewLoggerService()
	coordinator := services.NewSimpleTeamCoordinatorService(db, nil)
	llmFactory := llm.NewLLMClientFactory()

	return NewTeamOrchestrator(db, coordinator, llmFactory, logger)
}

// TestNewTeamOrchestrator 测试创建编排器
func TestNewTeamOrchestrator(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	assert.NotNil(t, orchestrator)
	assert.NotNil(t, orchestrator.db)
	assert.NotNil(t, orchestrator.coordinator)
	assert.NotNil(t, orchestrator.llmFactory)
	assert.NotNil(t, orchestrator.logger)
	assert.NotNil(t, orchestrator.runningTeams)
}

// TestCreateTeamFromPlan 测试从计划创建团队
func TestCreateTeamFromPlan(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	plan := &OrchestratorTeamPlan{
		ID:          uuid.New().String(),
		Name:        "Test Team",
		Description: "A test team for unit testing",
		Goal:        "Test goal",
		Members: []TeamMemberPlan{
			{
				ID:           uuid.New().String(),
				Name:         "Project Manager",
				Role:         "lead",
				Capabilities: []string{"planning", "coordination"},
				LLMModel:     "gpt-4",
			},
			{
				ID:           uuid.New().String(),
				Name:         "Developer",
				Role:         "developer",
				Capabilities: []string{"coding", "testing"},
				LLMModel:     "gpt-4",
			},
		},
		Tasks: []TaskPlanItem{
			{
				ID:          uuid.New().String(),
				Title:       "Task 1",
				Description: "First task",
				Type:        "coding",
				Priority:    "high",
				AssignedTo:  "", // 将在创建后设置
				Estimated:   60,
			},
			{
				ID:          uuid.New().String(),
				Title:       "Task 2",
				Description: "Second task",
				Type:        "testing",
				Priority:    "medium",
				AssignedTo:  "",
				Dependencies: []string{}, // 无依赖
				Estimated:   30,
			},
		},
		Config:    map[string]interface{}{"test": true},
		CreatedAt: time.Now(),
	}

	// 设置任务分配
	plan.Tasks[0].AssignedTo = plan.Members[1].ID // Developer
	plan.Tasks[1].AssignedTo = plan.Members[1].ID

	team, err := orchestrator.CreateTeamFromPlan(plan)
	assert.NoError(t, err)
	assert.NotNil(t, team)
	assert.NotEmpty(t, team.ID)
	assert.Equal(t, "Test Team", team.Name)
	assert.True(t, team.Enabled)

	// 验证成员已创建
	var members []models.TeamMember
	err = orchestrator.db.Where("team_id = ?", team.ID).Find(&members).Error
	assert.NoError(t, err)
	assert.Len(t, members, 2)

	// 验证任务已创建
	var tasks []models.Task
	err = orchestrator.db.Where("team_id = ?", team.ID).Find(&tasks).Error
	assert.NoError(t, err)
	assert.Len(t, tasks, 2)
}

// TestCreateTeamFromPlanValidation 测试计划验证
func TestCreateTeamFromPlanValidation(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	tests := []struct {
		name        string
		plan        *TeamPlan
		expectError bool
	}{
		{
			name: "Empty ID",
			plan: &TeamPlan{
				ID:    "",
				Name:  "Test",
				Members: []TeamMemberPlan{{ID: "1", Name: "M1", Role: "dev"}},
				Tasks:  []TaskPlanItem{{ID: "1", Title: "T1"}},
			},
			expectError: true,
		},
		{
			name: "Empty name",
			plan: &TeamPlan{
				ID:    uuid.New().String(),
				Name:  "",
				Members: []TeamMemberPlan{{ID: "1", Name: "M1", Role: "dev"}},
				Tasks:  []TaskPlanItem{{ID: "1", Title: "T1"}},
			},
			expectError: true,
		},
		{
			name: "No members",
			plan: &TeamPlan{
				ID:    uuid.New().String(),
				Name:  "Test",
				Members: []TeamMemberPlan{},
				Tasks:  []TaskPlanItem{{ID: "1", Title: "T1"}},
			},
			expectError: true,
		},
		{
			name: "No tasks",
			plan: &TeamPlan{
				ID:    uuid.New().String(),
				Name:  "Test",
				Members: []TeamMemberPlan{{ID: "1", Name: "M1", Role: "dev"}},
				Tasks:  []TaskPlanItem{},
			},
			expectError: true,
		},
		{
			name: "Invalid task assignment",
			plan: &TeamPlan{
				ID:    uuid.New().String(),
				Name:  "Test",
				Members: []TeamMemberPlan{{ID: "1", Name: "M1", Role: "dev"}},
				Tasks: []TaskPlanItem{{
					ID:         "1",
					Title:      "T1",
					AssignedTo: "non-existent-member",
				}},
			},
			expectError: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			_, err := orchestrator.CreateTeamFromPlan(tt.plan)
			if tt.expectError {
				assert.Error(t, err)
			} else {
				assert.NoError(t, err)
			}
		})
	}
}

// TestStartExecution 测试启动执行
func TestStartExecution(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	// 先创建团队
	plan := &TeamPlan{
		ID:          uuid.New().String(),
		Name:        "Execution Test Team",
		Description: "Test execution",
		Members: []TeamMemberPlan{
			{
				ID:   uuid.New().String(),
				Name: "Tester",
				Role: "tester",
				Capabilities: []string{"testing"},
			},
		},
		Tasks: []TaskPlanItem{
			{
				ID:          uuid.New().String(),
				Title:       "Test Task",
				Description: "A test task",
				Type:        "testing",
				Priority:    "low",
				AssignedTo:  "", // 将设置
				Estimated:   10,
			},
		},
		CreatedAt: time.Now(),
	}
	plan.Tasks[0].AssignedTo = plan.Members[0].ID

	team, err := orchestrator.CreateTeamFromPlan(plan)
	require.NoError(t, err)

	// 启动执行
	err = orchestrator.StartExecution(team.ID)
	assert.NoError(t, err)

	// 验证执行上下文已创建
	orchestrator.mu.RLock()
	_, exists := orchestrator.runningTeams[team.ID]
	orchestrator.mu.RUnlock()

	assert.True(t, exists, "Execution should be running")

	// 测试重复启动应该失败
	err = orchestrator.StartExecution(team.ID)
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "already running")
}

// TestStartExecutionNonExistentTeam 测试启动不存在的团队
func TestStartExecutionNonExistentTeam(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	err := orchestrator.StartExecution("non-existent-team")
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "not found")
}

// TestMonitorProgress 测试监控进度
func TestMonitorProgress(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	// 创建并启动团队
	plan := &TeamPlan{
		ID:          uuid.New().String(),
		Name:        "Monitor Test Team",
		Description: "Test progress monitoring",
		Members: []TeamMemberPlan{
			{
				ID:   uuid.New().String(),
				Name: "Monitor",
				Role: "monitor",
				Capabilities: []string{"monitoring"},
			},
		},
		Tasks: []TaskPlanItem{
			{
				ID:          uuid.New().String(),
				Title:       "Monitor Task 1",
				Description: "First monitoring task",
				Type:        "monitoring",
				Priority:    "medium",
				AssignedTo:  "",
				Estimated:   20,
			},
			{
				ID:          uuid.New().String(),
				Title:       "Monitor Task 2",
				Description: "Second monitoring task",
				Type:        "monitoring",
				Priority:    "low",
				AssignedTo:  "",
				Estimated:   15,
			},
		},
		CreatedAt: time.Now(),
	}
	plan.Tasks[0].AssignedTo = plan.Members[0].ID
	plan.Tasks[1].AssignedTo = plan.Members[0].ID

	team, err := orchestrator.CreateTeamFromPlan(plan)
	require.NoError(t, err)

	err = orchestrator.StartExecution(team.ID)
	require.NoError(t, err)

	// 监控进度
	report, err := orchestrator.MonitorProgress(team.ID)
	assert.NoError(t, err)
	assert.NotNil(t, report)
	assert.Equal(t, team.ID, report.TeamID)
	assert.NotNil(t, report.TaskStatus)
	assert.Equal(t, 2, report.TaskStatus.Total)
	assert.NotNil(t, report.MemberStats)
	assert.NotEmpty(t, report.Summary)
}

// TestMonitorProgressNonRunningTeam 测试监控未运行的团队
func TestMonitorProgressNonRunningTeam(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	err := orchestrator.StartExecution("non-existent-team")
	assert.Error(t, err)

	_, err = orchestrator.MonitorProgress("non-existent-team")
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "not running")
}

// TestAggregateResults 测试聚合结果
func TestAggregateResults(t *testing.T) {
	orchestrator := setupTestOrchestrator(t)

	// 创建团队
	plan := &TeamPlan{
		ID:          uuid.New().String(),
		Name:        "Results Test Team",
		Description: "Test result aggregation",
		Members: []TeamMemberPlan{
			{
				ID:   uuid.New().String(),
				Name: "Aggregator",
				Role: "aggregator",
				Capabilities: []string{"aggregation"},
			},
		},
		Tasks: []TaskPlanItem{
			{
				ID:          uuid.New().String(),
				Title:       "Result Task 1",
				Description: "First result task",
				Type:        "aggregation",
				Priority:    "high",
				AssignedTo:  "",
				Estimated:   30,
			},
			{
				ID:          uuid.New().String(),
				Title:       "Result Task 2",
				Description: "Second result task",
				Type:        "aggregation",
				Priority:    "medium",
				AssignedTo:  "",
				Estimated:   20,
			},
		},
		CreatedAt: time.Now(),
	}
	plan.Tasks[0].AssignedTo = plan.Members[0].ID
	plan.Tasks[1].AssignedTo = plan.Members[0].ID

	team, err := orchestrator.CreateTeamFromPlan(plan)
	require.NoError(t, err)

	// 手动更新任务状态以模拟执行
	var tasks []models.Task
	orchestrator.db.Where("team_id = ?", team.ID).Find(&tasks)
	require.Len(t, tasks, 2)

	// 标记第一个任务为完成
	now := time.Now()
	tasks[0].Status = "completed"
	tasks[0].StartedAt = &now
	tasks[0].CompletedAt = &now
	tasks[0].Result = &models.TaskResult{
		Success: true,
		Output:  "Task 1 completed successfully",
	}
	orchestrator.db.Save(&tasks[0])

	// 标记第二个任务为失败
	tasks[1].Status = "failed"
	tasks[1].StartedAt = &now
	tasks[1].Result = &models.TaskResult{
		Success: false,
		Error:   "Task 2 failed",
	}
	orchestrator.db.Save(&tasks[1])

	// 聚合结果
	result, err := orchestrator.AggregateResults(team.ID)
	assert.NoError(t, err)
	assert.NotNil(t, result)
	assert.Equal(t, team.ID, result.TeamID)
	assert.Equal(t, "Results Test Team", result.TeamName)
	assert.Equal(t, "partial", result.Status) // 部分完成
	assert.Equal(t, 2, result.TaskSummary.Total)
	assert.Equal(t, 1, result.TaskSummary.Completed)
	assert.Equal(t, 1, result.TaskSummary.Failed)
	assert.Len(t, result.MemberResults, 1)
	assert.NotEmpty(t, result.FinalOutput)
}

