	"github.com/glebarez/sqlite"
	"gorm.io/gorm"
)

// setupTestDBForUsage 创建测试数据库
func setupTestDBForUsage(t *testing.T) *gorm.DB {
	db, err := gorm.Open(sqlite.Open("file::memory:?cache=shared"), &gorm.Config{})
	require.NoError(t, err)

	err = db.AutoMigrate(
		&models.UsageRecord{},
		&models.DailyUsage{},
		&models.MonthlyUsage{},
		&models.ModelPricing{},
		&models.UserBudget{},
	)
	require.NoError(t, err)

	return db
}

// setupTestUsageService 创建测试服务
func setupTestUsageService(t *testing.T) *UsageService {
	db := setupTestDBForUsage(t)
	cache := NewCacheService()
	logger, _ := NewLoggerService(LogLevelInfo, "")

	return NewUsageService(db, cache, logger)
}

// TestNewUsageService 测试服务初始化
func TestNewUsageService(t *testing.T) {
	service := setupTestUsageService(t)

	assert.NotNil(t, service)
	assert.NotNil(t, service.db)
	assert.NotNil(t, service.cache)
	assert.NotNil(t, service.logger)
	assert.NotNil(t, service.pricing)

	// 验证默认定价已加载
	assert.Contains(t, service.pricing, "openai:gpt-4")
	assert.Contains(t, service.pricing, "anthropic:claude-3-opus")
	assert.Contains(t, service.pricing, "deepseek:deepseek-chat")
}

// TestInitDefaultPricing 测试默认定价初始化
func TestInitDefaultPricing(t *testing.T) {
	service := setupTestUsageService(t)

	// 验证各种提供商的定价
	pricingProviders := []struct {
		key    string
		input  float64
		output float64
	}{
		{"openai:gpt-4", 0.03, 0.06},
		{"openai:gpt-4-turbo", 0.01, 0.03},
		{"openai:gpt-3.5-turbo", 0.0005, 0.0015},
		{"anthropic:claude-3-opus", 0.015, 0.075},
		{"anthropic:claude-3-sonnet", 0.003, 0.015},
		{"deepseek:deepseek-chat", 0.0001, 0.0002},
		{"qwen:qwen-turbo", 0.0004, 0.0012},
		{"ollama:*", 0, 0},
	}

	for _, p := range pricingProviders {
		pricing, exists := service.pricing[p.key]
		assert.True(t, exists, "Pricing should exist for %s", p.key)
		if exists {
			assert.Equal(t, p.input, pricing.InputPricePer1K)
			assert.Equal(t, p.output, pricing.OutputPricePer1K)
		}
	}
}

// TestRecordUsage 测试记录使用量
func TestRecordUsage(t *testing.T) {
	service := setupTestUsageService(t)

	record := &models.UsageRecord{
		UserID:    uuid.New().String(),
		DialogueID: uuid.New().String(),
		MessageID:  uuid.New().String(),
		Provider:   "openai",
		ModelID:    "gpt-4",
		ModelName:  "gpt-4",
		PromptTokens:     1000,
		CompletionTokens: 500,
		TotalTokens:      1500,
		RequestType:      "chat",
		IsStreaming:      false,
		Duration:         1500,
		Success:          true,
	}

	err := service.RecordUsage(record)
	assert.NoError(t, err)
	assert.NotEmpty(t, record.ID)
	assert.Greater(t, record.TotalCost, 0.0)

	// 验证成本计算
	// gpt-4: input $0.03/1k, output $0.06/1k
	expectedInputCost := 1000.0 / 1000 * 0.03
	expectedOutputCost := 500.0 / 1000 * 0.06
	expectedTotal := expectedInputCost + expectedOutputCost

	assert.InDelta(t, expectedInputCost, record.InputCost, 0.0001)
	assert.InDelta(t, expectedOutputCost, record.OutputCost, 0.0001)
	assert.InDelta(t, expectedTotal, record.TotalCost, 0.0001)

	// 等待异步更新完成
	time.Sleep(100 * time.Millisecond)

	// 验证每日汇总已创建
	var dailyUsage models.DailyUsage
	today := time.Now().Format("2006-01-02")
	todayTime, _ := time.Parse("2006-01-02", today)
	err = service.db.Where("user_id = ? AND date = ?", record.UserID, todayTime).First(&dailyUsage).Error
	assert.NoError(t, err)
	assert.Equal(t, int64(1), dailyUsage.TotalRequests)
	assert.Equal(t, int64(1500), dailyUsage.TotalTokens)
}

// TestCalculateCost 测试成本计算
func TestCalculateCost(t *testing.T) {
	service := setupTestUsageService(t)

	tests := []struct {
		name           string
		provider       string
		modelName      string
		promptTokens   int64
		completionTokens int64
		expectedInput  float64
		expectedOutput float64
	}{
		{
			name:           "GPT-4",
			provider:       "openai",
			modelName:      "gpt-4",
			promptTokens:   1000,
			completionTokens: 1000,
			expectedInput:  0.03,
			expectedOutput: 0.06,
		},
		{
			name:           "GPT-3.5-turbo",
			provider:       "openai",
			modelName:      "gpt-3.5-turbo",
			promptTokens:   1000,
			completionTokens: 1000,
			expectedInput:  0.0005,
			expectedOutput: 0.0015,
		},
		{
			name:           "Claude-3-opus",
			provider:       "anthropic",
			modelName:      "claude-3-opus",
			promptTokens:   1000,
			completionTokens: 1000,
			expectedInput:  0.015,
			expectedOutput: 0.075,
		},
		{
			name:           "DeepSeek",
			provider:       "deepseek",
			modelName:      "deepseek-chat",
			promptTokens:   1000,
			completionTokens: 1000,
			expectedInput:  0.0001,
			expectedOutput: 0.0002,
		},
		{
			name:           "Ollama (free)",
			provider:       "ollama",
			modelName:      "llama2",
			promptTokens:   1000,
			completionTokens: 1000,
			expectedInput:  0,
			expectedOutput: 0,
		},
		{
			name:           "Unknown model (default pricing)",
			provider:       "unknown",
			modelName:      "unknown-model",
			promptTokens:   1000,
			completionTokens: 1000,
			expectedInput:  0.001, // 默认定价
			expectedOutput: 0.002,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			record := &models.UsageRecord{
				Provider:         tt.provider,
				ModelName:        tt.modelName,
				PromptTokens:     tt.promptTokens,
				CompletionTokens: tt.completionTokens,
			}

			service.calculateCost(record)

			assert.InDelta(t, tt.expectedInput, record.InputCost, 0.0001)
			assert.InDelta(t, tt.expectedOutput, record.OutputCost, 0.0001)
		})
	}
}

// TestUpdateDailyUsage 测试每日汇总更新
func TestUpdateDailyUsage(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()
	today := time.Now().Format("2006-01-02")
	todayTime, _ := time.Parse("2006-01-02", today)

	// 第一条记录
	record1 := &models.UsageRecord{
		UserID:           userID,
		Provider:         "openai",
		ModelName:        "gpt-3.5-turbo",
		PromptTokens:     1000,
		CompletionTokens: 500,
		TotalTokens:      1500,
		TotalCost:        0.0025,
	}
	service.updateDailyUsage(record1)

	// 第二条记录
	record2 := &models.UsageRecord{
		UserID:           userID,
		Provider:         "openai",
		ModelName:        "gpt-4",
		PromptTokens:     2000,
		CompletionTokens: 1000,
		TotalTokens:      3000,
		TotalCost:        0.09,
	}
	service.updateDailyUsage(record2)

	// 验证汇总
	var dailyUsage models.DailyUsage
	err := service.db.Where("user_id = ? AND date = ?", userID, todayTime).First(&dailyUsage).Error
	require.NoError(t, err)

	assert.Equal(t, int64(2), dailyUsage.TotalRequests)
	assert.Equal(t, int64(3000), dailyUsage.TotalPromptTokens)
	assert.Equal(t, int64(1500), dailyUsage.TotalCompletionTokens)
	assert.Equal(t, int64(4500), dailyUsage.TotalTokens)
	assert.InDelta(t, 0.0925, dailyUsage.TotalCost, 0.0001)
}

// TestUpdateMonthlyUsage 测试每月汇总更新
func TestUpdateMonthlyUsage(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()
	now := time.Now()
	year, month := now.Year(), int(now.Month())

	// 创建多条记录
	for i := 0; i < 3; i++ {
		record := &models.UsageRecord{
			UserID:           userID,
			Provider:         "openai",
			ModelName:        "gpt-3.5-turbo",
			PromptTokens:     1000,
			CompletionTokens: 500,
			TotalTokens:      1500,
			TotalCost:        0.0025,
		}
		service.updateMonthlyUsage(record)
	}

	// 验证汇总
	var monthlyUsage models.MonthlyUsage
	err := service.db.Where("user_id = ? AND year = ? AND month = ?", userID, year, month).
		First(&monthlyUsage).Error
	require.NoError(t, err)

	assert.Equal(t, int64(3), monthlyUsage.TotalRequests)
	assert.Equal(t, int64(3000), monthlyUsage.TotalPromptTokens)
	assert.Equal(t, int64(1500), monthlyUsage.TotalCompletionTokens)
	assert.Equal(t, int64(4500), monthlyUsage.TotalTokens)
}

