// TestUpdateModelPricing 测试更新模型定价
func TestUpdateModelPricing(t *testing.T) {
	service := setupTestUsageService(t)

	// 更新现有定价
	pricing := &models.ModelPricing{
		Provider:        "openai",
		ModelName:       "gpt-4",
		InputPricePer1K: 0.035, // 提价
		OutputPricePer1K: 0.065,
	}

	err := service.UpdateModelPricing(pricing)
	assert.NoError(t, err)

	// 验证更新
	retrieved, err := service.GetModelPricing("openai", "gpt-4")
	assert.NoError(t, err)
	assert.Equal(t, 0.035, retrieved.InputPricePer1K)
	assert.Equal(t, 0.065, retrieved.OutputPricePer1K)

	// 添加新定价
	newPricing := &models.ModelPricing{
		Provider:        "custom",
		ModelName:       "custom-model",
		InputPricePer1K: 0.001,
		OutputPricePer1K: 0.002,
	}

	err = service.UpdateModelPricing(newPricing)
	assert.NoError(t, err)

	retrieved, _ = service.GetModelPricing("custom", "custom-model")
	assert.Equal(t, 0.001, retrieved.InputPricePer1K)
}

// TestGetModelPricing 测试获取模型定价
func TestGetModelPricing(t *testing.T) {
	service := setupTestUsageService(t)

	// 测试获取已知模型
	pricing, err := service.GetModelPricing("openai", "gpt-4")
	assert.NoError(t, err)
	assert.NotNil(t, pricing)
	assert.Equal(t, "openai", pricing.Provider)
	assert.Equal(t, "gpt-4", pricing.ModelName)

	// 测试通配符匹配
	ollamaPricing, err := service.GetModelPricing("ollama", "any-model")
	assert.NoError(t, err)
	assert.NotNil(t, ollamaPricing)
	assert.Equal(t, 0.0, ollamaPricing.InputPricePer1K)

	// 测试不存在的模型
	_, err = service.GetModelPricing("unknown", "unknown-model")
	assert.Error(t, err)
}

