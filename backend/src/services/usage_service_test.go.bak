// TestUsageWithError 测试错误记录
func TestUsageWithError(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()

	record := &models.UsageRecord{
		UserID:       userID,
		Provider:     "openai",
		ModelName:    "gpt-4",
		PromptTokens: 1000,
		CompletionTokens: 0,
		TotalTokens:  1000,
		Success:      false,
		ErrorMessage: "Rate limit exceeded",
		Duration:     0,
	}

	err := service.RecordUsage(record)
	assert.NoError(t, err)

	// 成本仍然应该计算（基于输入tokens）
	assert.Greater(t, record.InputCost, 0.0)
	assert.Equal(t, 0.0, record.OutputCost)
}

// BenchmarkCostCalculation 性能测试
