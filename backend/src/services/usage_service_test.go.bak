// TestConcurrentUsageRecording 测试并发记录
func TestConcurrentUsageRecording(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()

	// 并发记录
	done := make(chan bool)
	for i := 0; i < 10; i++ {
		go func(index int) {
			record := &models.UsageRecord{
				UserID:    userID,
				Provider:  "openai",
				ModelName: "gpt-3.5-turbo",
				PromptTokens: int64(1000 * (index + 1)),
				CompletionTokens: int64(500 * (index + 1)),
				TotalTokens: int64(1500 * (index + 1)),
			}
			service.RecordUsage(record)
			done <- true
		}(i)
	}

	// 等待所有goroutine完成
	for i := 0; i < 10; i++ {
		<-done
	}

	// 等待异步更新
	time.Sleep(200 * time.Millisecond)

	// 验证所有记录都已保存
	var count int64
	service.db.Model(&models.UsageRecord{}).Where("user_id = ?", userID).Count(&count)
	assert.GreaterOrEqual(t, count, int64(10))
}

// TestBudgetAlertThresholds 测试预算警报阈值
func TestBudgetAlertThresholds(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()

	// 设置多个阈值
	thresholds := []int{25, 50, 75, 90, 100}
	err := service.SetUserBudget(userID, 100.0, 10.0, thresholds, "alert@example.com")
	require.NoError(t, err)

	budget, _ := service.GetUserBudget(userID)
	assert.Equal(t, 5, len(budget.AlertThresholds))

	// 验证阈值顺序
	for i := 0; i < len(thresholds)-1; i++ {
		assert.Less(t, thresholds[i], thresholds[i+1])
	}
}

// TestGetUsageStatsWithPeriods 测试不同周期的统计
func TestGetUsageStatsWithPeriods(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()

	// 创建一些历史数据
	for i := 0; i < 5; i++ {
		record := &models.UsageRecord{
			UserID:    userID,
			Provider:  "openai",
			ModelName: "gpt-3.5-turbo",
			PromptTokens: 1000,
			CompletionTokens: 500,
			TotalTokens: 1500,
			TotalCost:   0.0025,
			Success:     true,
		}
		service.RecordUsage(record)
	}

	time.Sleep(100 * time.Millisecond)

	periods := []string{"day", "week", "month"}
	for _, period := range periods {
		stats, err := service.GetUsageStats(userID, period)
		assert.NoError(t, err)
		assert.NotNil(t, stats)
		assert.Contains(t, stats, "total_requests")
	}
}

// TestWildcardPricing 测试通配符定价
func TestWildcardPricing(t *testing.T) {
	service := setupTestUsageService(t)

	// 测试 ollama 通配符
	ollamaModels := []string{"llama2", "mistral", "codellama"}
	for _, model := range ollamaModels {
		record := &models.UsageRecord{
			Provider: "ollama",
			ModelName: model,
			PromptTokens: 1000,
			CompletionTokens: 1000,
		}
		service.calculateCost(record)

		assert.Equal(t, 0.0, record.InputCost)
		assert.Equal(t, 0.0, record.OutputCost)
		assert.Equal(t, 0.0, record.TotalCost)
	}
}
