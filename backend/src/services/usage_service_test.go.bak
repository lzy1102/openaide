// TestGetUsageHistory 测试获取使用历史
func TestGetUsageHistory(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()

	// 创建多条记录
	for i := 0; i < 5; i++ {
		record := &models.UsageRecord{
			UserID:    userID,
			Provider:  "openai",
			ModelName: "gpt-3.5-turbo",
			PromptTokens: int64(1000 * (i + 1)),
			CompletionTokens: int64(500 * (i + 1)),
			TotalTokens: int64(1500 * (i + 1)),
		}
		service.RecordUsage(record)
	}

	// 等待记录保存
	time.Sleep(100 * time.Millisecond)

	// 获取历史
	history, err := service.GetUsageHistory(userID, time.Time{}, time.Time{}, 10)
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(history), 5)

	// 验证按时间倒序排列
	if len(history) >= 2 {
		assert.True(t, history[0].CreatedAt.After(history[1].CreatedAt) ||
			history[0].CreatedAt.Equal(history[1].CreatedAt))
	}
}

// TestGetUsageStats 测试获取使用统计
func TestGetUsageStats(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()

	// 创建测试数据
	providers := []string{"openai", "anthropic"}
	for _, provider := range providers {
		for i := 0; i < 3; i++ {
			record := &models.UsageRecord{
				UserID:           userID,
				Provider:         provider,
				ModelName:        provider + "-model",
				PromptTokens:     1000,
				CompletionTokens: 500,
				TotalTokens:      1500,
				TotalCost:        0.01,
				Success:          i != 1, // 一条失败
				Duration:         1000,
			}
			service.RecordUsage(record)
		}
	}

	time.Sleep(100 * time.Millisecond)

	// 获取统计
	stats, err := service.GetUsageStats(userID, "month")
	assert.NoError(t, err)

	// 验证统计数据
	assert.Contains(t, stats, "total_requests")
	assert.Contains(t, stats, "total_tokens")
	assert.Contains(t, stats, "total_cost")
	assert.Contains(t, stats, "by_model")
	assert.Contains(t, stats, "by_provider")
	assert.Contains(t, stats, "success_rate")
	assert.Contains(t, stats, "avg_duration_ms")

	totalRequests := stats["total_requests"].(int64)
	assert.GreaterOrEqual(t, totalRequests, int64(6))

	successRate := stats["success_rate"].(float64)
	assert.Greater(t, successRate, 0.0)
	assert.LessOrEqual(t, successRate, 100.0)
}

// TestSetUserBudget 测试设置用户预算
func TestSetUserBudget(t *testing.T) {
	service := setupTestUsageService(t)

	userID := uuid.New().String()
	thresholds := []int{50, 80, 100}

	// 设置新预算
	err := service.SetUserBudget(userID, 100.0, 10.0, thresholds, "test@example.com")
	assert.NoError(t, err)

	// 验证预算
	budget, err := service.GetUserBudget(userID)
	assert.NoError(t, err)
	assert.Equal(t, userID, budget.UserID)
	assert.Equal(t, 100.0, budget.MonthlyBudget)
	assert.Equal(t, 10.0, budget.DailyBudget)
	assert.Equal(t, thresholds, budget.AlertThresholds)
	assert.Equal(t, "test@example.com", budget.AlertEmail)

	// 更新预算
	err = service.SetUserBudget(userID, 200.0, 20.0, []int{75}, "updated@example.com")
	assert.NoError(t, err)

	budget, _ = service.GetUserBudget(userID)
	assert.Equal(t, 200.0, budget.MonthlyBudget)
	assert.Equal(t, "updated@example.com", budget.AlertEmail)
}

