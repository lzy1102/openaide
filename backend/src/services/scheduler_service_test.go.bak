// setupTestDBForScheduler 创建测试数据库
func setupTestDBForScheduler(t *testing.T) *gorm.DB {
	db, err := gorm.Open(sqlite.Open("file::memory:?cache=shared"), &gorm.Config{})
	require.NoError(t, err)

	err = db.AutoMigrate(
		&models.ScheduledTask{},
		&models.TaskExecution{},
		&models.TaskReminder{},
	)
	require.NoError(t, err)

	return db
}

// setupTestSchedulerService 创建测试调度服务
func setupTestSchedulerService(t *testing.T) *SchedulerService {
	db := setupTestDBForScheduler(t)
	logger, _ := NewLoggerService(LogLevelInfo, "")

	// 创建必要的依赖服务
	wsService := NewWebSocketService()
	workflowSvc := &WorkflowService{
		// 最小化配置用于测试
	}

	service := NewSchedulerService(db, logger, wsService, workflowSvc)

	return service
}

// TestNewSchedulerService 测试服务初始化
func TestNewSchedulerService(t *testing.T) {
	service := setupTestSchedulerService(t)

	assert.NotNil(t, service)
	assert.NotNil(t, service.db)
	assert.NotNil(t, service.logger)
	assert.NotNil(t, service.cron)
	assert.NotNil(t, service.tasks)
	assert.NotNil(t, service.ctx)
	assert.NotNil(t, service.cancel)
}

// TestCreateCronTask 测试创建Cron任务
