// TestListTasks 测试列出任务
func TestListTasks(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	// 创建多个任务
	for i := 0; i < 3; i++ {
		task := &models.ScheduledTask{
			Name:         "List test task",
			UserID:       userID,
			ScheduleType: "interval",
			Interval:     int64(60 * (i + 1)),
			TaskType:     "reminder",
		}
		service.CreateTask(task)
	}

	// 列出用户任务
	tasks, err := service.ListTasks(userID)
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(tasks), 3)

	// 验证都是该用户的任务
	for _, task := range tasks {
		assert.Equal(t, userID, task.UserID)
	}

	// 列出所有任务
	allTasks, err := service.ListTasks("")
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(allTasks), len(tasks))
}

// TestExecuteNow 测试立即执行任务
func TestExecuteNow(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	task := &models.ScheduledTask{
		Name:         "Execute now test",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     3600,
		TaskType:     "notification",
		TaskConfig: map[string]interface{}{
			"title": "Test",
			"body":  "Test body",
		},
	}
	err := service.CreateTask(task)
	require.NoError(t, err)

	// 立即执行
	execution, err := service.ExecuteNow(task.ID, userID)
	assert.NoError(t, err)
	assert.NotNil(t, execution)
	assert.Equal(t, task.ID, execution.TaskID)
	assert.Equal(t, "manual", execution.TriggerType)
	assert.Equal(t, userID, execution.TriggeredBy)

	// 验证执行状态是成功或失败（不是running）
	assert.NotEqual(t, "running", execution.Status)
}

// TestGetExecutions 测试获取执行历史
func TestGetExecutions(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	task := &models.ScheduledTask{
		Name:         "Execution history test",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     60,
		TaskType:     "notification",
		TaskConfig: map[string]interface{}{
			"title": "Test",
			"body":  "Test",
		},
	}
	err := service.CreateTask(task)
	require.NoError(t, err)

	// 执行几次
	for i := 0; i < 3; i++ {
		service.ExecuteNow(task.ID, userID)
	}

	// 获取执行历史
	executions, err := service.GetExecutions(task.ID, 10)
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(executions), 3)

	// 验证按时间倒序
	if len(executions) >= 2 {
		assert.True(t, executions[0].StartedAt.After(executions[1].StartedAt) ||
			executions[0].StartedAt.Equal(executions[1].StartedAt))
	}
}

