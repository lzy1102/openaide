// TestValidateSchedule 测试调度验证
func TestValidateSchedule(t *testing.T) {
	service := setupTestSchedulerService(t)

	tests := []struct {
		name        string
		task        *models.ScheduledTask
		expectError bool
	}{
		{
			name: "Valid cron",
			task: &models.ScheduledTask{
				ScheduleType: "cron",
				CronExpr:     "0 9 * * *",
			},
			expectError: false,
		},
		{
			name: "Invalid cron",
			task: &models.ScheduledTask{
				ScheduleType: "cron",
				CronExpr:     "invalid cron",
			},
			expectError: true,
		},
		{
			name: "Valid interval",
			task: &models.ScheduledTask{
				ScheduleType: "interval",
				Interval:     60,
			},
			expectError: false,
		},
		{
			name: "Invalid interval",
			task: &models.ScheduledTask{
				ScheduleType: "interval",
				Interval:     0,
			},
			expectError: true,
		},
		{
			name: "Valid once task",
			task: &models.ScheduledTask{
				ScheduleType: "once",
				ExecuteAt:    func() *time.Time { t := time.Now().Add(1 * time.Hour); return &t }(),
			},
			expectError: false,
		},
		{
			name: "Past once task",
			task: &models.ScheduledTask{
				ScheduleType: "once",
				ExecuteAt:    func() *time.Time { t := time.Now().Add(-1 * time.Hour); return &t }(),
			},
			expectError: true,
		},
		{
			name: "Unsupported type",
			task: &models.ScheduledTask{
				ScheduleType: "unsupported",
			},
			expectError: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := service.validateSchedule(tt.task)
			if tt.expectError {
				assert.Error(t, err)
			} else {
				assert.NoError(t, err)
			}
		})
	}
}

// TestCalculateNextRun 测试计算下次运行时间
func TestCalculateNextRun(t *testing.T) {
	service := setupTestSchedulerService(t)

	// Cron任务
	cronTask := &models.ScheduledTask{
		ScheduleType: "cron",
		CronExpr:     "0 9 * * *", // 每天9点
	}
	nextRun := service.calculateNextRun(cronTask)
	assert.NotNil(t, nextRun)
	assert.True(t, nextRun.After(time.Now()))

	// Interval任务
	intervalTask := &models.ScheduledTask{
		ScheduleType: "interval",
		Interval:     300, // 5分钟
	}
	nextRun = service.calculateNextRun(intervalTask)
	assert.NotNil(t, nextRun)
	expectedMin := time.Now().Add(4 * time.Minute).Minute()
	expectedMax := time.Now().Add(6 * time.Minute).Minute()
	assert.GreaterOrEqual(t, nextRun.Minute(), expectedMin)
	assert.LessOrEqual(t, nextRun.Minute(), expectedMax)

	// Once任务
	futureTime := time.Now().Add(1 * time.Hour)
	onceTask := &models.ScheduledTask{
		ScheduleType: "once",
		ExecuteAt:    &futureTime,
	}
	nextRun = service.calculateNextRun(onceTask)
	assert.NotNil(t, nextRun)
	assert.Equal(t, futureTime.Unix(), nextRun.Unix())
}

// TestPauseTask 测试暂停任务
func TestPauseTask(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	task := &models.ScheduledTask{
		Name:         "Task to pause",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     60,
		TaskType:     "reminder",
	}
	err := service.CreateTask(task)
	require.NoError(t, err)

	// 暂停任务
	err = service.PauseTask(task.ID)
	assert.NoError(t, err)

	// 验证状态
	var paused models.ScheduledTask
	err = service.db.First(&paused, task.ID).Error
	require.NoError(t, err)
	assert.Equal(t, "paused", paused.Status)
	assert.False(t, paused.IsEnabled)

	// 验证不再在调度器中
	_, exists := service.tasks[task.ID]
	assert.False(t, exists)
}

// TestResumeTask 测试恢复任务
func TestResumeTask(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	task := &models.ScheduledTask{
		Name:         "Task to resume",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     60,
		TaskType:     "reminder",
	}
	err := service.CreateTask(task)
	require.NoError(t, err)

	// 先暂停
	service.PauseTask(task.ID)

	// 恢复任务
	err = service.ResumeTask(task.ID)
	assert.NoError(t, err)

	// 验证状态
	var resumed models.ScheduledTask
	err = service.db.First(&resumed, task.ID).Error
	require.NoError(t, err)
	assert.Equal(t, "active", resumed.Status)
	assert.True(t, resumed.IsEnabled)
}

