// TestSnoozeReminder 测试延后提醒
func TestSnoozeReminder(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	reminder := &models.TaskReminder{
		UserID:   userID,
		Title:    "Snooze test",
		Content:  "Test content",
		RemindAt: time.Now().Add(1 * time.Hour),
		Status:   "pending",
	}
	service.db.Create(reminder)

	originalTime := reminder.RemindAt

	// 延后30分钟
	err := service.SnoozeReminder(reminder.ID, 30)
	assert.NoError(t, err)

	// 验证时间已更新
	var updated models.TaskReminder
	service.db.First(&updated, reminder.ID)
	assert.True(t, updated.RemindAt.After(originalTime))
	assert.Equal(t, "pending", updated.Status)
	assert.Equal(t, 1, updated.SnoozeCount)
	assert.NotNil(t, updated.SnoozedAt)
}

