// TestLoadActiveTasks 测试加载活跃任务
func TestLoadActiveTasks(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	// 创建一些活跃任务
	for i := 0; i < 3; i++ {
		task := &models.ScheduledTask{
			Name:         "Active task",
			UserID:       userID,
			ScheduleType: "interval",
			Interval:     int64(60 * (i + 1)),
			TaskType:     "reminder",
			Status:       "active",
			IsEnabled:    true,
		}
		service.db.Create(task)
	}

	// 创建非活跃任务
	inactiveTask := &models.ScheduledTask{
		Name:         "Inactive task",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     60,
		TaskType:     "reminder",
		Status:       "paused",
		IsEnabled:    false,
	}
	service.db.Create(inactiveTask)

	// 加载活跃任务
	service.loadActiveTasks()

	// 验证至少有一些任务被加载
	// 注意：由于服务初始化时已经加载过，这里只是验证方法不报错
	assert.NotNil(t, service.tasks)
}

// TestStop 测试停止服务
func TestStop(t *testing.T) {
	service := setupTestSchedulerService(t)

	// 停止服务（不应该panic）
	service.Stop()

	// 验证cron已停止
	assert.False(t, service.cron.IsRunning())
}

// BenchmarkTaskCreation 性能测试
func BenchmarkTaskCreation(b *testing.B) {
	service := setupTestSchedulerService(&testing.T{})
	userID := uuid.New().String()

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		task := &models.ScheduledTask{
			Name:         "Benchmark task",
			UserID:       userID,
			ScheduleType: "interval",
			Interval:     60,
			TaskType:     "reminder",
		}
		service.CreateTask(task)
	}
}

// TestConcurrentTaskOperations 测试并发操作
func TestConcurrentTaskOperations(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	done := make(chan bool)

	// 并发创建任务
	for i := 0; i < 10; i++ {
		go func(index int) {
			task := &models.ScheduledTask{
				Name:         "Concurrent task",
				UserID:       userID,
				ScheduleType: "interval",
				Interval:     int64(60 * (index + 1)),
				TaskType:     "reminder",
			}
			service.CreateTask(task)
			done <- true
		}(i)
	}

	// 等待所有goroutine
	for i := 0; i < 10; i++ {
		<-done
	}

	// 验证所有任务都已创建
	tasks, _ := service.ListTasks(userID)
	assert.GreaterOrEqual(t, len(tasks), 10)
}
