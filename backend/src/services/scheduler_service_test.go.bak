// TestGetReminders 测试获取提醒列表
func TestGetReminders(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	// 创建多个提醒
	reminders := []models.TaskReminder{
		{
			UserID:   userID,
			Title:    "Pending reminder",
			Content:  "Pending",
			RemindAt: time.Now().Add(1 * time.Hour),
			Status:   "pending",
		},
		{
			UserID:   userID,
			Title:    "Sent reminder",
			Content:  "Sent",
			RemindAt: time.Now().Add(-1 * time.Hour),
			Status:   "sent",
		},
	}

	for _, r := range reminders {
		r.ID = uuid.New().String()
		service.db.Create(&r)
	}

	// 获取所有提醒
	all, err := service.GetReminders(userID, "")
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(all), 2)

	// 获取待处理提醒
	pending, err := service.GetReminders(userID, "pending")
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(pending), 1)

	// 获取已发送提醒
	sent, err := service.GetReminders(userID, "sent")
	assert.NoError(t, err)
	assert.GreaterOrEqual(t, len(sent), 1)
}

// TestCalculateNextReminder 测试计算下次提醒时间
func TestCalculateNextReminder(t *testing.T) {
	service := setupTestSchedulerService(t)

	baseTime := time.Date(2024, 1, 1, 10, 0, 0, 0, time.UTC)

	tests := []struct {
		name       string
		repeatType string
		expected   time.Time
	}{
		{
			name:       "Daily",
			repeatType: "daily",
			expected:   baseTime.Add(24 * time.Hour),
		},
		{
			name:       "Weekly",
			repeatType: "weekly",
			expected:   baseTime.AddDate(0, 0, 7),
		},
		{
			name:       "Monthly",
			repeatType: "monthly",
			expected:   baseTime.AddDate(0, 1, 0),
		},
		{
			name:       "Yearly",
			repeatType: "yearly",
			expected:   baseTime.AddDate(1, 0, 0),
		},
		{
			name:       "None",
			repeatType: "none",
			expected:   time.Time{}, // zero value
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			reminder := &models.TaskReminder{
				RemindAt:   baseTime,
				RepeatType: tt.repeatType,
			}

			next := service.calculateNextReminder(reminder)

			if tt.repeatType == "none" {
				assert.True(t, next.IsZero())
			} else {
				assert.NotNil(t, next)
				assert.Equal(t, tt.expected.Unix(), next.Unix())
			}
		})
	}
}

// TestTaskExpiration 测试任务过期
func TestTaskExpiration(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	// 创建已过期的任务
	pastTime := time.Now().Add(-1 * time.Hour)
	task := &models.ScheduledTask{
		Name:         "Expired task",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     60,
		TaskType:     "reminder",
		ExpiresAt:    &pastTime,
	}
	err := service.CreateTask(task)
	require.NoError(t, err)

	// 尝试执行 - 应该因为过期而暂停
	service.executeTask(task.ID)

	// 验证任务已暂停
	var updated models.ScheduledTask
	service.db.First(&updated, task.ID)
	assert.Equal(t, "paused", updated.Status)
}

// TestTaskMaxRuns 测试最大运行次数
func TestTaskMaxRuns(t *testing.T) {
	service := setupTestSchedulerService(t)
	userID := uuid.New().String()

	task := &models.ScheduledTask{
		Name:         "Max runs test",
		UserID:       userID,
		ScheduleType: "interval",
		Interval:     1,
		TaskType:     "notification",
		TaskConfig: map[string]interface{}{
			"title": "Test",
			"body":  "Test",
		},
		MaxRuns:  3,
		RunCount: 2, // 已运行2次
	}
	service.db.Create(task)

	// 设置为活跃状态
	task.Status = "active"
	task.IsEnabled = true
	service.db.Save(task)

	// 执行第3次
	service.executeTask(task.ID)

	// 验证运行次数增加
	var updated models.ScheduledTask
	service.db.First(&updated, task.ID)
	assert.Equal(t, int64(3), updated.RunCount)
	assert.Equal(t, "paused", updated.Status) // 达到最大次数后暂停
}

